{{ $pages := .RegularPages }}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>Une veille technocritique, par Arnaud Levy</title>
    <link>{{ .Permalink }}</link>
    <description>Contenus de veille récents</description>
    <generator>Hugo</generator>
    <language>{{ site.Language.LanguageCode }}</language>
    <managingEditor>contact@arnaudlevy.com (Arnaud Levy)</managingEditor>{{ if not .Date.IsZero }}
    <lastBuildDate>{{ (index $pages.ByLastmod.Reverse 0).Lastmod.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</lastBuildDate>{{ end }}
    {{- with .OutputFormats.Get "RSS" }}
    {{ printf "<atom:link href=%q rel=\"self\" type=%q />" .Permalink .MediaType | safeHTML }}
    {{- end }}
    {{- range $pages }}
      {{- $description := .Summary | plainify | chomp }}
      {{- $description = replace $description "&rsquo;" "’" }}
      {{- $description = replace $description "&hellip;" "..." }}
      {{- $description = $description }}
      <item>
        <title>{{ replace .Title "'" "‘" }}</title>
        <link>{{ .Permalink }}</link>
        <origLink>{{ .Params.source }}</origLink>
        <pubDate>{{ .PublishDate.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</pubDate>
        <guid>{{ .Permalink }}</guid>
        <description>{{ $description }}</description>
      </item>
    {{- end -}}
  </channel>
</rss>
